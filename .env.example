# Example environment variables
# Copy this file to .env and edit the values

# VPN credentials (if using a VPN service)
OPENVPN_USER=your_vpn_username
OPENVPN_PASSWORD=your_vpn_password

# Timezone
TZ=Europe/Madrid

# User and group IDs for file permissions (find with `id -u` and `id -g`)
PUID=1000
PGID=1000